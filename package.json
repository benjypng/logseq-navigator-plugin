{
  "name": "logseq-navigator-plugin",
  "author": "benjypng",
  "description": "A three-pane note navigator that replaces the underused native left sidebar in Logseq DB graphs.",
  "license": "MIT",
  "logseq": {
    "id": "logseq-navigator-plugin",
    "title": "Navigator",
    "icon": "./icon.svg",
    "main": "dist/index.html",
    "unsupportedGraphType": "file"
  },
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "prepare": "husky",
    "lint:precommit": "echo \"Running biome\" && bunx biome check . --write && echo \"Running tsc\" && tsc --noEmit"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      [
        "@semantic-release/github",
        {
          "assets": ["logseq-navigator-plugin.zip"]
        }
      ]
    ]
  },
  "dependencies": {
    "@logseq/libs": "^0.3.3",
    "@tanstack/react-virtual": "^3.14.2",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-logseq": "^1.1.2",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
